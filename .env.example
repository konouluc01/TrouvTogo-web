# =============================================================================
# TrouvTogo — variables d’environnement (Vite)
# Copier vers .env et adapter. Les clés préfixées VITE_ sont exposées au navigateur.
# =============================================================================

# Nom court de l’application (marque, futurs titres / métadonnées)
VITE_APP_NAME=TrouvTogo

# URL de base de l’API Spring Boot, sans slash final (ex. https://api.example.com).
#
# • Développement avec backend local + proxy Vite : laisser VIDE pour que les
#   requêtes partent en relatif (/api/…) et soient proxifiées vers VITE_PROXY_API.
# • Développement ou prod pointant directement l’API : définir l’URL complète.
#
VITE_API_URL=

# Vidéo hero : URL absolue ou chemin depuis la racine du site (dossier public/ en dev/build).
# Ex. fichier copié dans public/video/hero-bg.mp4 →
# VITE_HERO_VIDEO_URL=/video/hero-bg.mp4
# Laisser vide pour utiliser l’MP4 importé depuis src/assets/video/hero-bg.mp4
# VITE_HERO_VIDEO_URL=

# -----------------------------------------------------------------------------
# Uniquement pour `npm run dev` — cible du proxy /api (voir vite.config.ts)
# -----------------------------------------------------------------------------
VITE_PROXY_API=http://localhost:8081

# -----------------------------------------------------------------------------
# Backend Spring (référence déploiement) — à définir sur l’API, pas dans le front
# -----------------------------------------------------------------------------
# APP_CORS_ALLOWED_ORIGINS=https://trouvtogo.example.com,http://localhost:5173
